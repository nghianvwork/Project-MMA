# Backend API base URL
# Android emulator: http://10.0.2.2:3000
# iOS simulator: http://localhost:3000
# Physical device: http://<your-lan-ip>:3000
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_API_BASE_URL_FALLBACK=http://127.0.0.1:3000
# Optional: add LAN IP if testing from another device/browser
# EXPO_PUBLIC_API_BASE_URL_2=http://192.168.1.10:3000
EXPO_PUBLIC_USER_ID=user123
# Optional display name fallback (if not using profile token)
EXPO_PUBLIC_USER_NAME=
# Optional JWT token to load profile from /api/user/profile
EXPO_PUBLIC_AUTH_TOKEN=

# Google OAuth client IDs
# You can set 1 common ID or separate IDs by platform.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=857502113791-d9h25p90ll9lqkqel1j6s9tpsmdtat02.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=857502113791-0rh5d4apj9ocr8eir9ftfmp9br1b8qvg.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=857502113791-d9h25p90ll9lqkqel1j6s9tpsmdtat02.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=857502113791-d9h25p90ll9lqkqel1j6s9tpsmdtat02.apps.googleusercontent.com
# Optional for Expo Go proxy. Format: @<expo-username>/<slug>
# EXPO_PUBLIC_GOOGLE_PROXY_PROJECT_NAME=@your-expo-username/mobile
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=857502113791-0rh5d4apj9ocr8eir9ftfmp9br1b8qvg.apps.googleusercontent.com
# For Expo web OAuth callback (must match Google Console Authorized redirect URI exactly)
EXPO_PUBLIC_GOOGLE_WEB_REDIRECT_URI=http://localhost:8081/
