# Backend API base URL
# Android emulator: http://10.0.2.2:3000
# iOS simulator: http://localhost:3000
# Physical device: http://<your-lan-ip>:3000
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_API_BASE_URL_FALLBACK=http://127.0.0.1:3000


EXPO_PUBLIC_API_BASE_URL=http://192.168.0.102:3000
EXPO_PUBLIC_API_BASE_URL_FALLBACK=http://localhost:3000

main
# Optional: add LAN IP if testing from another device/browser
# EXPO_PUBLIC_API_BASE_URL_2=http://192.168.1.10:3000
EXPO_PUBLIC_USER_ID=user123
# Optional display name fallback (if not using profile token)
EXPO_PUBLIC_USER_NAME=
# Optional JWT token to load profile from /api/user/profile
EXPO_PUBLIC_AUTH_TOKEN=
EXPO_PUBLIC_EAS_PROJECT_ID=

# Google OAuth client IDs
# You can set 1 common ID or separate IDs by platform.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=577208075366-q81quhp28cfc3eto7jl1p0aref3fgq1s.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=577208075366-q81quhp28cfc3eto7jl1p0aref3fgq1s.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=577208075366-q81quhp28cfc3eto7jl1p0aref3fgq1s.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=577208075366-q81quhp28cfc3eto7jl1p0aref3fgq1s.apps.googleusercontent.com
# Optional for Expo Go proxy. Format: @<expo-username>/<slug>
EXPO_PUBLIC_GOOGLE_PROXY_PROJECT_NAME=@duyanh1191/mobile
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=577208075366-q81quhp28cfc3eto7jl1p0aref3fgq1s.apps.googleusercontent.com
# For Expo web OAuth callback (must match Google Console Authorized redirect URI exactly)
EXPO_PUBLIC_GOOGLE_WEB_REDIRECT_URI=http://localhost:8081/